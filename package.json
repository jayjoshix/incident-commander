{
  "name": "lineagelock",
  "version": "1.0.0",
  "description": "GitHub PR guard for data changes — blast radius, governance risk, and contract compatibility powered by OpenMetadata",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "dry-run": "ts-node src/cli.ts",
    "demo": "ts-node src/cli.ts demo",
    "action": "ts-node src/action/main.ts",
    "seed": "ts-node scripts/seed-openmetadata.ts",
    "integration-test": "ts-node scripts/integration-test.ts",
    "live-test": "node scripts/live-sandbox-test.js",
    "dashboard": "node scripts/dashboard.js",
    "website": "node scripts/website.js",
    "setup-om": "bash scripts/setup-openmetadata.sh",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "openmetadata",
    "lineage",
    "github-action",
    "data-governance",
    "blast-radius",
    "dbt",
    "pr-review",
    "data-quality"
  ],
  "author": "LineageLock Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "axios": "^1.7.0",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "glob": "^10.3.0",
    "minimatch": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/minimatch": "^5.1.0",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
