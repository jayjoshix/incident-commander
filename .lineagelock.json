{
  "paths": {
    "sql": ["models/**/*.sql", "sql/**/*.sql"],
    "yaml": ["models/**/*.yml", "models/**/*.yaml", "schemas/**/*.yml"]
  },
  "naming": {
    "service": "acme_nexus_analytics",
    "database": "ANALYTICS",
    "schema": "MARTS",
    "nameStrategy": "filename"
  },
  "mappings": [
    {
      "filePattern": "models/staging/**/*.sql",
      "fqn": "acme_nexus_analytics.ANALYTICS.STAGING.{name}"
    },
    {
      "filePattern": "models/marts/**/*.sql",
      "fqn": "acme_nexus_analytics.ANALYTICS.MARTS.{name}"
    },
    {
      "filePattern": "models/metrics/**/*.sql",
      "fqn": "acme_nexus_analytics.ANALYTICS.METRICS.{name}"
    }
  ],
  "sensitiveTags": {
    "keywords": ["PII", "GDPR", "Confidential", "Sensitive", "PHI", "PCI", "DataSensitivity"]
  },
  "criticalTiers": ["Tier1", "Tier2", "Tier.Tier1", "Tier.Tier2"],
  "highDownstreamThreshold": 5,
  "thresholds": {
    "warn": 30,
    "fail": 70
  },
  "weights": {
    "contractViolation": 40,
    "criticalTier": 20,
    "sensitiveTags": 20,
    "downstreamDashboards": 10,
    "downstreamMlModels": 10,
    "highDownstreamCount": 10,
    "noOwner": 10
  },
  "failOnUnresolved": false,
  "automation": {
    "reviewers": {
      "enabled": true,
      "ownerMapping": {
        "data-engineering": "data-eng-lead",
        "analytics-team": "analytics-lead"
      },
      "maxReviewers": 3
    },
    "labels": {
      "enabled": true
    },
    "notifications": {
      "minLevel": "HIGH",
      "slackWebhookUrl": "",
      "teamsWebhookUrl": "",
      "webhookUrl": ""
    }
  }
}
