# ============================================================
# OpenMetadata Incident Commander — Environment Variables
# ============================================================
# Copy to .env and fill in values for live OpenMetadata mode.
# Leave blank / commented out to run in Mock Mode.

# OpenMetadata server base URL (no trailing slash)
# Example: http://localhost:8585
VITE_OPENMETADATA_URL=

# OpenMetadata JWT or personal access token
# Generate from: Settings → Bots → ingestion-bot → token
VITE_OPENMETADATA_TOKEN=
