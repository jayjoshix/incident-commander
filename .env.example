# OpenMetadata connection
OPENMETADATA_URL=http://localhost:8585
OPENMETADATA_TOKEN=your-jwt-token-here

# GitHub (auto-provided in Actions)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LineageLock thresholds
LINEAGELOCK_WARN_THRESHOLD=30
LINEAGELOCK_FAIL_THRESHOLD=70
LINEAGELOCK_CONFIG_PATH=.lineagelock.json
